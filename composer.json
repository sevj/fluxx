{
    "name": "sevj/fluxx",
    "description": "Fluxx synchronization workflow bundle for Symfony.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "doctrine/doctrine-bundle": "^3.2 || ^4.0",
        "doctrine/orm": "^3.3",
        "doctrine/persistence": "^4.0",
        "php": "^8.3",
        "symfony/console": "^7.3 || ^8.0",
        "symfony/config": "^7.3 || ^8.0",
        "symfony/dependency-injection": "^7.3 || ^8.0",
        "symfony/framework-bundle": "^7.3 || ^8.0",
        "symfony/http-kernel": "^7.3 || ^8.0",
        "symfony/messenger": "^7.3 || ^8.0",
        "symfony/password-hasher": "^7.3 || ^8.0",
        "symfony/security-core": "^7.3 || ^8.0",
        "symfony/security-http": "^7.3 || ^8.0",
        "symfony/twig-bundle": "^7.3 || ^8.0",
        "symfony/yaml": "^7.3 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Fluxx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fluxx\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "Fluxx\\FluxxBundle"
        },
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.4 || ^13.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
