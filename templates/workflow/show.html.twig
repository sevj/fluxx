{% trans_default_domain 'fluxx' %}
{% import '@Fluxx/_icons.html.twig' as icons %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ workflow.name }} - {{ 'workflow_show.title'|trans }}</title>
    <link rel="icon" type="image/png" href="{{ path('fluxx_favicon_asset', {v: '20260616-favicon'}) }}">
    <script src="{{ path('fluxx_script_asset', {'script': 'theme', v: '20260616-js-split'}) }}"></script>
    <script src="{{ path('fluxx_script_asset', {'script': 'workflow-detail', v: '20260616-js-split'}) }}"></script>
    <link rel="stylesheet" href="{{ path('fluxx_workflow_stylesheet', {v: '20260616'}) }}">
</head>
<body>
    <main class="page">
        {% include '@Fluxx/_navigation.html.twig' %}

        <div class="page-stack">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <section class="section-card">
                        <div class="status-badge status-badge-{{ type == 'error' ? 'failed' : 'completed' }}">{{ message }}</div>
                    </section>
                {% endfor %}
            {% endfor %}

            <header class="header">
                <div>
                    <h1 class="title">{{ workflow.name }}</h1>
                    <div class="item-code item-code-hero">{{ workflow.code }}</div>
                </div>
                <div class="header-actions">
                    <a href="{{ path('fluxx_workflow_index') }}" class="secondary-button">
                        <span class="button-icon" aria-hidden="true">{{ icons.icon('arrow-left') }}</span>
                        <span class="button-label">{{ 'workflow_show.back'|trans }}</span>
                    </a>
                </div>
            </header>

            <section class="section-card">
                <div class="section-heading">
                    <div>
                        <h2 class="section-title">{{ 'workflow_show.definition_title'|trans }}</h2>
                    </div>
                </div>

                <div class="workflow-definition-groups workflow-definition-summary">
                    <section class="definition-block definition-block-compact">
                        <div class="definition-label">{{ 'workflow_show.systems_group'|trans }}</div>
                        <div class="definition-inline-list">
                            <div class="definition-inline-item">
                                <span class="definition-inline-key">{{ 'workflow_show.source_system'|trans }}</span>
                                <span class="system-chip system-chip-source">{{ workflow.sourceSystem }}</span>
                            </div>
                            <div class="definition-inline-item">
                                <span class="definition-inline-key">{{ 'workflow_show.target_system'|trans }}</span>
                                <span class="system-chip system-chip-target">{{ workflow.targetSystem }}</span>
                            </div>
                        </div>
                    </section>

                    <section class="definition-block definition-block-compact">
                        <div class="definition-label">{{ 'workflow_show.executions_group'|trans }}</div>
                        <div class="definition-inline-list">
                            <div class="definition-inline-item">
                                <span class="definition-inline-key">{{ 'workflow_show.execution_count'|trans }}</span>
                                <span class="definition-inline-value">{{ workflow.executionCount }}</span>
                            </div>
                            <div class="definition-inline-item">
                                <span class="definition-inline-key">{{ 'workflow_show.error_count'|trans }}</span>
                                <span class="definition-inline-value">{{ workflow.errorCount }}</span>
                            </div>
                            <div class="definition-inline-item">
                                <span class="definition-inline-key">{{ 'workflow_show.last_execution'|trans }}</span>
                                {% if workflow.lastExecutionAt %}
                                    <span class="definition-inline-value">{{ workflow.lastExecutionAt|date('Y-m-d H:i') }}</span>
                                {% else %}
                                    <span class="metric-empty">{{ 'workflow_show.never'|trans }}</span>
                                {% endif %}
                            </div>
                            <div class="definition-inline-item">
                                <span class="definition-inline-key">{{ 'workflow_show.last_error'|trans }}</span>
                                {% if workflow.lastErrorAt %}
                                    <span class="definition-inline-value metric-error">{{ workflow.lastErrorAt|date('Y-m-d H:i') }}</span>
                                {% else %}
                                    <span class="metric-empty">{{ 'workflow_show.no_error'|trans }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </section>
                </div>
            </section>

            <nav
                class="section-tabs"
                aria-label="{{ 'workflow_show.tabs_label'|trans }}"
                data-tabs
                data-tab-base-url="{{ path('fluxx_workflow_tab_show', {'code': workflow.code, 'tab': '__tab__'}) }}"
                data-tab-loading-label="{{ 'workflow_show.tab_loading'|trans }}"
                data-tab-error-label="{{ 'workflow_show.tab_error'|trans }}"
                data-tab-poll-pause-label="{{ 'workflow_show.pause_polling'|trans }}"
                data-tab-poll-resume-label="{{ 'workflow_show.resume_polling'|trans }}"
                data-tab-poll-loading-label="{{ 'workflow_show.polling'|trans }}"
                data-tab-poll-state-live-label="{{ 'workflow_show.state_live'|trans }}"
                data-tab-poll-state-error-label="{{ 'workflow_show.state_error'|trans }}"
                data-tab-poll-state-offline-label="{{ 'workflow_show.state_offline'|trans }}"
                data-tab-poll-refresh-failed-label="{{ 'workflow_show.refresh_failed'|trans }}"
            >
                <button type="button" class="section-tab is-active" data-tab-button="steps" aria-selected="true" aria-controls="workflow-tab-steps">
                    <span class="button-icon" aria-hidden="true">{{ icons.icon('list') }}</span>
                    <span class="button-label">{{ 'workflow_show.tab_steps'|trans }}</span>
                </button>
                <button type="button" class="section-tab" data-tab-button="executions" aria-selected="false" aria-controls="workflow-tab-executions">
                    <span class="button-icon" aria-hidden="true">{{ icons.icon('activity') }}</span>
                    <span class="button-label">{{ 'workflow_show.tab_executions'|trans }}</span>
                </button>
                <button type="button" class="section-tab" data-tab-button="statistics" aria-selected="false" aria-controls="workflow-tab-statistics">
                    <span class="button-icon" aria-hidden="true">{{ icons.icon('bar-chart-3') }}</span>
                    <span class="button-label">{{ 'workflow_show.tab_statistics'|trans }}</span>
                </button>
            </nav>

            <section id="workflow-tab-steps" class="section-card" data-tab-panel="steps">
                <div data-tab-content="steps">
                    <section class="empty">{{ 'workflow_show.tab_loading'|trans }}</section>
                </div>
            </section>

            <section id="workflow-tab-executions" class="section-card" data-tab-panel="executions" hidden>
                <div class="polling-controls">
                    <span class="status-badge status-badge-pending" data-executions-state>{{ 'workflow_show.loading'|trans }}</span>
                    <button
                        type="button"
                        class="secondary-button"
                        data-executions-poll-toggle
                        aria-pressed="true"
                    >
                        <span class="button-icon button-icon-toggle" aria-hidden="true">
                            <span class="icon-when-active">{{ icons.icon('pause') }}</span>
                            <span class="icon-when-inactive">{{ icons.icon('play') }}</span>
                        </span>
                        <span class="button-label" data-button-label>{{ 'workflow_show.pause_polling'|trans }}</span>
                    </button>
                    <span class="polling-indicator" data-executions-poll-loader hidden>
                        <span class="polling-spinner" aria-hidden="true"></span>
                        <span>{{ 'workflow_show.polling'|trans }}</span>
                    </span>
                    <span class="runtime-refresh" data-executions-refresh>{{ 'workflow_show.waiting'|trans }}</span>
                </div>
                <div data-tab-content="executions">
                    <section class="empty">{{ 'workflow_show.tab_loading'|trans }}</section>
                </div>
            </section>

            <section id="workflow-tab-statistics" class="section-card" data-tab-panel="statistics" hidden>
                <div data-tab-content="statistics">
                    <section class="empty">{{ 'workflow_show.tab_loading'|trans }}</section>
                </div>
            </section>
        </div>
    </main>
</body>
</html>
